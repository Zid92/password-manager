<Window x:Class="PasswordManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PasswordManager.ViewModels"
        mc:Ignorable="d"
        Title="Settings" 
        MinHeight="350" MinWidth="380"
        Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="12,10" Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" 
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16">
            <StackPanel>
                <!-- General Section -->
                <TextBlock Text="General" 
                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Margin="0,0,0,12"/>

                <materialDesign:Card Padding="14" Margin="0,0,0,16" 
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start with Windows" FontWeight="Medium"/>
                                <TextBlock Text="Launch automatically on system startup"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" 
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding StartWithWindows}"/>
                        </Grid>

                        <Separator Margin="0,4"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Minimize to tray" FontWeight="Medium"/>
                                <TextBlock Text="Hide to system tray when closing window"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" 
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding MinimizeToTray}"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Hotkey Section -->
                <TextBlock Text="Hotkey" 
                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Margin="0,0,0,12"/>

                <materialDesign:Card Padding="14" Margin="0,0,0,16"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="Quick Insert shortcut" FontWeight="Medium"/>
                        <TextBlock Text="Click the field below and press your desired key combination"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox x:Name="HotkeyInput"
                                     Grid.Column="0"
                                     Text="{Binding HotkeyDisplay, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Press key combination..."
                                     FontWeight="Bold"
                                     FontSize="16"
                                     PreviewKeyDown="HotkeyInput_PreviewKeyDown"/>
                            
                            <Border Grid.Column="1" 
                                    Background="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Current" 
                                           Foreground="White"
                                           FontSize="12"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
                
                <!-- Error message -->
                <Border Background="#FFEBEE" 
                        BorderBrush="#F44336" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Foreground="#F44336" 
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#C62828"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" 
                BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}" 
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,8,0"/>
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
