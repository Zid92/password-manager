<Window x:Class="PasswordManager.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PasswordManager.ViewModels"
        mc:Ignorable="d"
        Title="Password Manager - Вход" 
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel, IsDesignTimeCreatable=False}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="24" Grid.Row="0">
            <StackPanel HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="ShieldKey" Width="64" Height="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Password Manager" 
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Login Form -->
        <materialDesign:Card Grid.Row="1" Margin="24" Padding="24" 
                             VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp4">
            <StackPanel>
                <!-- Title based on first run or not -->
                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24">
                    <TextBlock.Text>
                        <Binding Path="IsFirstRun">
                            <Binding.Converter>
                                <local:BoolToStringConverter TrueValue="Создание хранилища" FalseValue="Разблокировка"
                                                              xmlns:local="clr-namespace:PasswordManager.Converters"/>
                            </Binding.Converter>
                        </Binding>
                    </TextBlock.Text>
                </TextBlock>

                <!-- Master Password -->
                <PasswordBox x:Name="MasterPasswordBox"
                             materialDesign:HintAssist.Hint="Мастер-пароль"
                             Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                             Margin="0,0,0,16"/>

                <!-- Confirm Password (only for first run) -->
                <PasswordBox x:Name="ConfirmPasswordBox"
                             materialDesign:HintAssist.Hint="Подтвердите пароль"
                             Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                             Margin="0,0,0,16"
                             Visibility="{Binding IsFirstRun, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Enable Windows Hello checkbox (only for first run) -->
                <CheckBox Content="Включить Windows Hello"
                          IsChecked="{Binding EnableWindowsHello}"
                          Margin="0,0,0,16"
                          Visibility="{Binding IsFirstRun, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsEnabled="{Binding IsWindowsHelloAvailable}"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}"/>

                <!-- Unlock Button -->
                <Button Content="Разблокировать"
                        Command="{Binding UnlockCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        Margin="0,0,0,16"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Divider -->
                <Grid Margin="0,8">
                    <Separator/>
                    <TextBlock Text="или" 
                               HorizontalAlignment="Center" 
                               Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                               Padding="8,0"/>
                </Grid>

                <!-- Windows Hello Button -->
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding UnlockWithWindowsHelloCommand}"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        Visibility="{Binding IsFirstRun, Converter={StaticResource InverseBoolToVisConverter}}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Fingerprint" Margin="0,0,8,0"/>
                        <TextBlock Text="Windows Hello"/>
                    </StackPanel>
                </Button>

                <!-- Loading Indicator -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             HorizontalAlignment="Center"
                             Margin="0,16,0,0"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
