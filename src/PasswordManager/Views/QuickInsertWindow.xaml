<Window x:Class="PasswordManager.Views.QuickInsertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PasswordManager.ViewModels"
        mc:Ignorable="d"
        Title="Quick Insert" 
        MinHeight="300" MinWidth="350"
        Height="420" Width="480"
        MaxHeight="600" MaxWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        d:DataContext="{d:DesignInstance Type=vm:QuickInsertViewModel, IsDesignTimeCreatable=False}">
    
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
        <KeyBinding Key="Down" Command="{Binding SelectNextCommand}"/>
        <KeyBinding Key="Up" Command="{Binding SelectPreviousCommand}"/>
        <KeyBinding Key="Return" Command="{Binding InsertBothCommand}"/>
        <KeyBinding Key="U" Modifiers="Ctrl" Command="{Binding InsertUsernameCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding InsertPasswordCommand}"/>
    </Window.InputBindings>

    <Border CornerRadius="8" 
            Background="{DynamicResource MaterialDesign.Brush.Background}"
            BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
            BorderThickness="2">
        <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <materialDesign:ColorZone Mode="PrimaryMid" Padding="10,8" Grid.Row="0" CornerRadius="6,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <materialDesign:PackIcon Kind="KeyboardOutline" Width="20" Height="20" 
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Quick Insert" 
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Column="1"
                                   Text="Ctrl+U: username | Ctrl+P: password | Enter: both"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Opacity="0.8"
                                   FontSize="10"/>
                    </Grid>
                </materialDesign:ColorZone>

                <!-- Search -->
                <TextBox x:Name="SearchBox"
                         Grid.Row="1"
                         materialDesign:HintAssist.Hint="Search..."
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="10,10,10,6"/>

                <!-- Credentials List -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Credentials}"
                         SelectedItem="{Binding SelectedCredential}"
                         Margin="10,0,10,10"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Background="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                                        CornerRadius="14"
                                        Width="28" Height="28"
                                        VerticalAlignment="Center" 
                                        Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Title[0]}" 
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" 
                                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Username}" 
                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Bottom buttons -->
                <WrapPanel Grid.Row="3" 
                           HorizontalAlignment="Right" 
                           Margin="10,0,10,10">
                    <Button Content="Username"
                            Command="{Binding InsertUsernameCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="12,4"
                            Margin="0,0,6,0"
                            FontSize="12"/>
                    <Button Content="Password"
                            Command="{Binding InsertPasswordCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="12,4"
                            Margin="0,0,6,0"
                            FontSize="12"/>
                    <Button Content="Both"
                            Command="{Binding InsertBothCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Padding="16,4"
                            FontSize="12"/>
                </WrapPanel>
            </Grid>
        </materialDesign:Card>
    </Border>
</Window>
