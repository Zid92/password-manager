<Window x:Class="PasswordManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PasswordManager.ViewModels"
        xmlns:converters="clr-namespace:PasswordManager.Converters"
        mc:Ignorable="d"
        Title="Password Manager" 
        MinHeight="400" MinWidth="500"
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">
    
    <materialDesign:DialogHost IsOpen="{Binding IsDialogOpen}" CloseOnClickAway="False">
        <materialDesign:DialogHost.DialogContent>
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          MaxHeight="500"
                          HorizontalScrollBarVisibility="Disabled">
                <materialDesign:Card Padding="24" MinWidth="350" MaxWidth="450">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                   Margin="0,0,0,20"
                                   Text="{Binding IsEditMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Edit Entry|New Entry'}"/>

                        <!-- Title field with validation -->
                        <TextBox Text="{Binding DialogTitle, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 materialDesign:HintAssist.Hint="Title *"
                                 materialDesign:HintAssist.HelperText="e.g. Google, GitHub"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16"/>

                        <!-- Username field -->
                        <TextBox Text="{Binding DialogUsername, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Username"
                                 materialDesign:HintAssist.HelperText="email or username"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16"/>

                        <!-- Password field with validation -->
                        <TextBox Text="{Binding DialogPassword, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 materialDesign:HintAssist.Hint="Password *"
                                 materialDesign:HintAssist.HelperText="your password"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16"/>

                        <!-- URL field -->
                        <TextBox Text="{Binding DialogUrl, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="URL"
                                 materialDesign:HintAssist.HelperText="https://example.com"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16"/>

                        <!-- Notes field -->
                        <TextBox Text="{Binding DialogNotes, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Notes"
                                 materialDesign:HintAssist.HelperText="optional notes"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 MaxHeight="100"
                                 VerticalContentAlignment="Top"
                                 Margin="0,0,0,16"/>

                        <!-- General Error Message -->
                        <Border Background="#FFEBEE" 
                                BorderBrush="#F44336" 
                                BorderThickness="1" 
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,12"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#F44336" 
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#C62828"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Command="{Binding CancelDialogCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Save"
                                    Command="{Binding SaveCredentialCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </ScrollViewer>
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <materialDesign:ColorZone Mode="PrimaryMid" Padding="12,8" Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldKey" Width="28" Height="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Password Manager" 
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Search -->
                    <TextBox Grid.Column="1"
                             materialDesign:HintAssist.Hint="Search..." 
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Background="White"
                             Margin="16,0"
                             MaxWidth="400"
                             HorizontalAlignment="Stretch"/>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                        <!-- Breach check status -->
                        <StackPanel Orientation="Horizontal" 
                                    Visibility="{Binding IsBreachCheckRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,8,0">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="{Binding BreachCheckProgress}"
                                         IsIndeterminate="False"
                                         Width="20" Height="20"/>
                            <TextBlock Text="{Binding BreachCheckStatus}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       Foreground="White"
                                       FontSize="11"
                                       MaxWidth="120"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                Command="{Binding CheckBreachesCommand}"
                                ToolTip="Check passwords for breaches"
                                IsEnabled="{Binding IsBreachCheckRunning, Converter={StaticResource InverseBooleanConverter}}">
                            <materialDesign:PackIcon Kind="ShieldAlert" Width="20" Height="20"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                ToolTip="Settings"
                                Click="SettingsButton_Click">
                            <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                Command="{Binding LockCommand}"
                                ToolTip="Logout">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                Click="ExitButton_Click"
                                ToolTip="Exit">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:ColorZone>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="12">
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasCredentials, Converter={StaticResource InverseBoolToVisConverter}}">
                    <materialDesign:PackIcon Kind="KeyPlus" Width="56" Height="56" 
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                    <TextBlock Text="No saved passwords" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,6"/>
                    <TextBlock Text="Add your first entry by clicking the + button" 
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Credentials List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasCredentials, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Credentials}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Padding="12" Margin="0,0,0,8"
                                                     materialDesign:ElevationAssist.Elevation="Dp2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" 
                                                Background="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                                                CornerRadius="18"
                                                Width="36" Height="36"
                                                VerticalAlignment="Center" 
                                                Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Title[0]}" 
                                                       FontSize="16" FontWeight="Medium"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="100">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" 
                                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="200"/>
                                                <materialDesign:PackIcon Kind="AlertCircle" 
                                                                         Foreground="Red"
                                                                         Width="16" Height="16"
                                                                         Margin="6,0,0,0"
                                                                         VerticalAlignment="Center"
                                                                         ToolTip="Password compromised!"
                                                                         Visibility="{Binding IsBreached, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Username}" 
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="200"/>
                                            <TextBlock Text="{Binding Url}" 
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="200"
                                                       Visibility="{Binding Url, Converter={StaticResource NullableToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Copy username"
                                                    Width="36" Height="36"
                                                    Command="{Binding DataContext.CopyUsernameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="AccountCircle" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Copy password"
                                                    Width="36" Height="36"
                                                    Command="{Binding DataContext.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Edit"
                                                    Width="36" Height="36"
                                                    Command="{Binding DataContext.EditCredentialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Delete"
                                                    Width="36" Height="36"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                    Command="{Binding DataContext.DeleteCredentialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Loading -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
            </Grid>

            <!-- FAB -->
            <Button Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                    Command="{Binding AddCredentialCommand}"
                    ToolTip="Add entry"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,20"
                    Grid.Row="1"
                    Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                    Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}">
                <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
            </Button>
        </Grid>
    </materialDesign:DialogHost>
</Window>
